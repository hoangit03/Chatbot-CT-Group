# ============================================
# LLM Config — vLLM Server
# ============================================
LLM_PROVIDER=vllm
MODEL_LLM=Qwen/Qwen2.5-3B-Instruct
VLLM_BASE_URL=http://vllm:8000/v1
TEMPERATURE=0.1

# ============================================
# Data Config
# ============================================
DIR_DATA_RAW=data/raw
SHARED_DATA_DIR=./shared_data

# ============================================
# Chunking Config
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=250

# ============================================
# Embedding Config
# ============================================
EMBED_DEVICE=cuda
EMBEDDING_MODEL_GPU=intfloat/multilingual-e5-large
EMBEDDING_MODEL_CPU=intfloat/multilingual-e5-large

# ============================================
# VectorStore Config
# ============================================
VECTOR_STORE_TYPE=chroma
VECTOR_DB_DIR=./vectorstore/chroma_db

# ============================================
# Retrieval Config
# ============================================
RETRIEVAL_TOP_K=6

# ============================================
# Reranker Config
# ============================================
RERANKER_ENABLED=true
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_TOP_K=30
RERANKER_DEVICE=cuda

# ============================================
# Infrastructure — Docker network hostnames
# ============================================
CHROMA_HOST=chroma_server
CHROMA_PORT=8000
RABBITMQ_HOST=rabbitmq_server
RABBITMQ_PORT=5672
PADDLE_OCR_ENDPOINT=http://paddleocr_server:8080/layout-parsing
WORKER_NODE_IP=localhost
