# ============================================
# LLM Config
# ============================================
MODEL_LLM=qwen3:1.7b
TEMPERATURE=0.3

# ============================================
# Data Config
# ============================================
DIR_DATA_RAW=data/raw
SHARED_DATA_DIR=./shared_data

# ============================================
# Chunking Config
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ============================================
# Embedding Config
# ============================================
# EMBED_DEVICE quyết định model nào được sử dụng:
#   cuda → EMBEDDING_MODEL_GPU (intfloat/multilingual-e5-large, 1024-dim)
#   cpu  → EMBEDDING_MODEL_CPU (paraphrase-multilingual-MiniLM-L12-v2, 384-dim)
EMBED_DEVICE=cuda
EMBEDDING_MODEL_GPU=intfloat/multilingual-e5-large
EMBEDDING_MODEL_CPU=paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# VectorStore Config
# ============================================
VECTOR_STORE_TYPE=chroma
VECTOR_DB_DIR=./vectorstore/chroma_db

# ============================================
# Retrieval Config
# ============================================
RETRIEVAL_TOP_K=8

# ============================================
# Reranker Config
# ============================================
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=15

# ============================================
# RabbitMQ Config (ETL Pipeline)
# ============================================
RABBITMQ_HOST=localhost
