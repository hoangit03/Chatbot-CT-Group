# ============================================
# LLM Config (Core vLLM service)
# ============================================
VLLM_BASE_URL=http://core_vllm:8000/v1
LLM_PROVIDER=vllm
MODEL_LLM=Qwen/Qwen2.5-7B-Instruct-AWQ
TEMPERATURE=0.1

# ============================================
# Data Config
# ============================================
DIR_DATA_RAW=data/raw
SHARED_DATA_DIR=./shared_data

# ============================================
# Chunking Config
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ============================================
# Embedding Config (Core Embedding service)
# ============================================
CORE_EMBED_URL=http://core_embedding:8004
EMBEDDING_MODEL_GPU=intfloat/multilingual-e5-large

# ============================================
# VectorStore Config (Core Infra — ChromaDB)
# ============================================
VECTOR_STORE_TYPE=chroma
CHROMA_HOST=core_chroma
CHROMA_PORT=8000

# ============================================
# Retrieval Config
# ============================================
RETRIEVAL_TOP_K=4

# ============================================
# Reranker Config (Core Reranker service)
# ============================================
RERANKER_ENABLED=true
CORE_RERANKER_URL=http://core_reranker:8009
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_TOP_K=10

# ============================================
# RabbitMQ Config (Core Infra)
# ============================================
RABBITMQ_HOST=core_rabbitmq
RABBITMQ_PORT=5672

# ============================================
# Redis Config (Core Infra)
# ============================================
REDIS_HOST=core_redis
REDIS_PORT=6379

# ============================================
# PaddleOCR Config (Core Service)
# ============================================
PADDLE_OCR_ENDPOINT=http://core_paddleocr:8080/layout-parsing
